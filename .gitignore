# ==========================================
# Ensoniq SD-1 MAME VST .gitignore
# ==========================================

# JUCE-specific folders (generated by Projucer)
Builds/*
!Builds/LinuxMakefile/
Builds/LinuxMakefile/build/

JuceLibraryCode/
*.user
*.suo

# Compiled binaries and VST files
*.vst3
*.component
*.a
*.o
*.dylib
*.dll
*.exe
*.lib

# macOS-specific hidden system files
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
__MACOSX/

# Xcode-specific
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.xcworkspace/
!default.xcworkspace/

# Windows / Visual Studio specific
.vs/
Debug/
Release/
x64/
x86/
*.ncb
*.sdf
*.opensdf
*.pdb